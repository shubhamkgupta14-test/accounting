# API routing is deployment-specific. `/api` uses the Vite proxy in development
# and the current origin in a deployed build.
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Optional development/test-only login helpers. Leave blank outside disposable
# local environments. There are deliberately no credential defaults in code.
VITE_DEMO_SUPERADMIN_EMAIL=
VITE_DEMO_ADMIN_EMAIL=
VITE_DEMO_USER_EMAIL=
VITE_DEMO_PASSWORD=

# The development port defaults to 5173 in vite.config.ts. UI defaults such as
# the application name are defined under src/config/.
