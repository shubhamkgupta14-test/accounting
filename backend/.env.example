APP_NAME=Accounting
ENV=local
UVICORN_PORT=8000
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=accounting
JWT_SECRET=replace-with-a-long-local-secret
JWT_EXPIRES_MINUTES=480
JWT_ISSUER=accounting-api
JWT_AUDIENCE=accounting-app
AUTH_COOKIE_NAME=accounting_session
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost:8443,http://127.0.0.1:8443,http://localhost:5173,http://127.0.0.1:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@accounting.local
OTP_EXPIRES_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
MAX_JSON_BODY_BYTES=2097152
MAX_EXCEL_UPLOAD_BYTES=5242880
MAX_EXCEL_UNCOMPRESSED_BYTES=26214400
MAX_EXCEL_ROWS=20000
MAX_EXCEL_COLUMNS=50
MAX_EXCEL_NEW_ACCOUNTS=500
API_REQUESTS_PER_MINUTE=240
REPORT_REQUESTS_PER_MINUTE=60
IMPORT_REQUESTS_PER_MINUTE=12
MAX_COMPARATIVE_PERIODS=10
MAX_REPORT_ROWS=20000
