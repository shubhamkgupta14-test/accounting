# Required deployment identity and data connection
ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=accounting

# Required secret: use a unique random value of at least 32 characters
JWT_SECRET=replace-with-a-long-local-secret

# Explicit browser/API trust boundaries
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_HOSTS=localhost,127.0.0.1
COOKIE_SECURE=false

# Optional email delivery for password reset
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@accounting.local

# Non-secret defaults such as ports, JWT lifetime/claims, cookie name/SameSite,
# OTP timing, upload limits, report limits, and API quotas are defined in
# app/core/config.py. Add an uppercase override here only when customization is
# required for a deployment.
