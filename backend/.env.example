APP_NAME=Accounting
ENV=local
UVICORN_PORT=8000
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=accounting
JWT_SECRET=replace-with-a-long-local-secret
JWT_EXPIRES_MINUTES=1440
CORS_ORIGINS=http://localhost:8443,http://127.0.0.1:8443,http://localhost:5173,http://127.0.0.1:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@accounting.local
OTP_EXPIRES_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
